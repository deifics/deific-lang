struct Point:
    x: int
    y: int

func add(a: int, b: int) -> int:
    return a + b

func test_addition():
    assert(add(2, 3) == 5)
    assert(add(-1, 1) == 0)

func test_struct_fields():
    p = Point(7, 8)
    assert(p.x == 7)
    assert(p.y == 8)

func test_intentional_failure():
    assert(1 == 2)
