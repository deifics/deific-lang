# Read N integers, sort them, print their sum and the sorted list.
# Demonstrates: input(), int(), read_ints(), inference, for/range, indexing,
# method calls (.sort()), and the fast-I/O runtime.

def main():
    n = int(input())
    a = read_ints(n)
    a.sort()
    total = 0
    for i in range(n):
        total = total + a[i]
    print(total)
    print(a)
