# Normalise line endings to LF in the repo; check out as-is on all platforms
* text=auto eol=lf

# Deific source files
*.df text eol=lf

# Rust source
*.rs text eol=lf

# Generated / binary artefacts — never diff
*.exe binary
*.dll binary
*.so  binary
*.a   binary

# C++ intermediate files generated by the compiler — treat as text for diffs
*.cpp text eol=lf
